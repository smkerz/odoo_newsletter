<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- MC Davidian Newsletter — QWeb Theme Template -->
    <template id="theme_mcdavidian_template">

        <style id="design-element">
            h1, h2, h3 { font-family: Georgia, 'Times New Roman', serif; font-weight: 400; }
            p, p > *, li, li > * { color: #444444; }
            a { color: #c9a96e; }
        </style>

        <!-- HEADER NOIR + LOGO -->
        <div class="s_text_block o_mail_snippet_general"
             style="background-color: #1a1a1a; padding: 32px 40px; text-align: center;">
            <div class="container s_allow_columns">
                <a href="https://www.mcdavidian.com" target="_blank" style="text-decoration: none;">
                    <img src="/web/image/website/1/logo"
                         alt="MC Davidian"
                         width="220"
                         style="display: inline-block; max-width: 220px; height: auto;" />
                </a>
                <p style="margin: 12px 0 0 0; font-family: Georgia, 'Times New Roman', serif; font-size: 13px; letter-spacing: 3px; color: #c9a96e; text-transform: uppercase;">
                    Lunetterie Artisanale depuis 1980
                </p>
            </div>
        </div>

        <!-- HERO IMAGE -->
        <div class="s_text_image o_mail_snippet_general"
             style="padding: 0; line-height: 0;">
            <div class="container s_allow_columns" style="padding: 0;">
                <img src="https://placehold.co/600x300/1a1a1a/c9a96e?text=MC+Davidian"
                     alt="MC Davidian Collection"
                     style="display: block; width: 100%; max-width: 600px; height: auto;" />
            </div>
        </div>

        <!-- TITRE + SOUS-TITRE -->
        <div class="s_text_block o_mail_snippet_general"
             style="padding: 40px 48px 8px 48px; text-align: center;">
            <div class="container s_allow_columns">
                <h1 style="margin: 0 0 16px 0; font-size: 28px; line-height: 1.3; color: #1a1a1a;">
                    Nouvelle Collection Printemps 2026
                </h1>
                <p style="margin: 0; font-family: Georgia, 'Times New Roman', serif; font-size: 15px; font-style: italic; color: #c9a96e; letter-spacing: 1px;">
                    Acétate de cellulose &amp; cristaux Swarovski
                </p>
            </div>
        </div>

        <!-- SEPARATEUR DORE -->
        <div class="s_hr o_mail_snippet_general" style="padding: 16px 48px; text-align: center;">
            <div class="container s_allow_columns">
                <hr style="width: 60px; border: none; border-top: 2px solid #c9a96e; margin: 0 auto;" />
            </div>
        </div>

        <!-- CONTENU PRINCIPAL -->
        <div class="s_text_block o_mail_snippet_general"
             style="padding: 0 48px 24px 48px;">
            <div class="container s_allow_columns">
                <p style="margin: 0 0 16px 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.7; text-align: center;">
                    Cher partenaire,
                </p>
                <p style="margin: 0 0 16px 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.7; text-align: left;">
                    Nous avons le plaisir de vous présenter notre nouvelle collection de lunettes artisanales, façonnées à la main dans notre atelier français. Chaque monture est taillée dans de l'acétate de cellulose véritable et ornée de cristaux Swarovski® authentiques.
                </p>
                <p style="margin: 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.7; text-align: left;">
                    Découvrez les pièces phares de cette saison et les conditions exclusives réservées à nos partenaires professionnels.
                </p>
            </div>
        </div>

        <!-- BOUTON CTA -->
        <div class="s_btn o_mail_snippet_general"
             style="padding: 8px 48px 40px 48px; text-align: center;">
            <div class="container s_allow_columns">
                <a href="https://www.mcdavidian.com/collections"
                   target="_blank"
                   class="btn"
                   style="display: inline-block; padding: 14px 40px; background-color: #c9a96e; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: #ffffff; text-decoration: none; border-radius: 2px; border: none;">
                    Découvrir la collection
                </a>
            </div>
        </div>

        <!-- BLOC PRODUITS 2 COLONNES -->
        <div class="s_three_columns o_mail_snippet_general"
             style="padding: 0 48px 40px 48px;">
            <div class="container s_allow_columns">
                <div class="row">
                    <div class="col-6" style="text-align: center;">
                        <img src="https://placehold.co/240x160/f8f6f3/1a1a1a?text=Modele+1"
                             alt="Modele Riviera"
                             style="display: block; width: 100%; max-width: 240px; height: auto; margin: 0 auto; border-radius: 2px;" />
                        <h3 style="margin: 12px 0 4px 0; font-size: 16px; color: #1a1a1a;">
                            Modèle Riviera
                        </h3>
                        <p style="margin: 0; font-size: 13px; color: #888888;">
                            Acétate havane • Cristaux dorés
                        </p>
                    </div>
                    <div class="col-6" style="text-align: center;">
                        <img src="https://placehold.co/240x160/f8f6f3/1a1a1a?text=Modele+2"
                             alt="Modele Opale"
                             style="display: block; width: 100%; max-width: 240px; height: auto; margin: 0 auto; border-radius: 2px;" />
                        <h3 style="margin: 12px 0 4px 0; font-size: 16px; color: #1a1a1a;">
                            Modèle Opale
                        </h3>
                        <p style="margin: 0; font-size: 13px; color: #888888;">
                            Acétate noir • Cristaux argentés
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- CITATION BANDEAU NOIR -->
        <div class="s_text_block o_mail_snippet_general"
             style="background-color: #1a1a1a; padding: 32px 48px; text-align: center;">
            <div class="container s_allow_columns">
                <p style="margin: 0; font-family: Georgia, 'Times New Roman', serif; font-size: 17px; font-style: italic; line-height: 1.6; color: #c9a96e;">
                    « Chaque monture raconte une histoire. La vôtre. »
                </p>
            </div>
        </div>

        <!-- FOOTER -->
        <div class="s_text_block o_mail_snippet_general"
             style="padding: 32px 48px; border-top: 1px solid #eeeeee; text-align: center;">
            <div class="container s_allow_columns">
                <p style="margin: 0 0 4px 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1a1a1a; text-transform: uppercase; letter-spacing: 1px;">
                    MC Davidian
                </p>
                <p style="margin: 0 0 16px 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 12px; color: #999999; line-height: 1.6;">
                    Lunetterie Artisanale Française<br/>
                    <a href="mailto:marie@news.mcdavidian.com" style="color: #c9a96e; text-decoration: none;">marie@news.mcdavidian.com</a>
                    &#160;•&#160;
                    <a href="https://www.mcdavidian.com" target="_blank" style="color: #c9a96e; text-decoration: none;">mcdavidian.com</a>
                </p>
            </div>
        </div>

        <!-- UNSUBSCRIBE (géré par Odoo nativement via s_mail_block_footer) -->
        <t t-call="mass_mailing.s_mail_block_footer_social_left"/>

    </template>

</odoo>
